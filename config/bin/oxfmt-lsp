#!/usr/bin/env bash
# Start the oxfmt LSP only in projects that actually use oxfmt (an .oxfmtrc.json
# somewhere at or above the working directory). There, run the workspace-local
# oxfmt so the editor's formatter version matches the project (and CI
# `oxfmt --check`), falling back to a global oxfmt. Elsewhere, hand the editor a
# no-op LSP so it neither errors on start nor takes over formatting from
# prettier. Args after the marker are passed to oxfmt (the editor adds --lsp).
set -euo pipefail

tool=oxfmt
marker=.oxfmtrc.json

dir=$PWD
while [[ "$dir" != / ]]; do
  if [[ -f "$dir/$marker" ]]; then
    if [[ -x "$dir/node_modules/.bin/$tool" ]]; then
      exec "$dir/node_modules/.bin/$tool" "$@"
    fi
    exec "$tool" "$@"
  fi
  dir=$(dirname -- "$dir")
done

exec noop-lsp
